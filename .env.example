GITHUB_TOKEN=your_github_personal_access_token_here

# MongoDB Atlas (M0 free tier)
# Atlas → Database Access: create a DB user (not your Atlas login password)
# Atlas → Network Access: allow your IP
# Atlas → Connect → Drivers → copy connection string
# Replace placeholders with real values — do NOT keep the < > brackets
# Wrong:  ...user:<myPass123>@cluster...
# Right:  ...user:myPass123@cluster...
MONGODB_URI=mongodb+srv://db_username:db_password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=developer_growth_tracker
# Only needed if auth fails; Atlas database users usually use admin
# MONGODB_AUTH_SOURCE=admin

# How long cached profiles are kept (hours). MongoDB TTL auto-deletes expired docs.
CACHE_TTL_HOURS=6
